# ──────────────────────────────────────────────────────────────
# Email (Resend) — https://resend.com
# ──────────────────────────────────────────────────────────────
# Create an API key in the Resend dashboard after verifying mafbootcamp.com.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address. Must be on a domain you've verified in Resend.
FROM_EMAIL=applications@mafbootcamp.com

# Where new application notifications (with CV attached) are delivered.
# This is YOUR inbox — applications land here.
NOTIFICATION_EMAIL=YOUR_GMAIL_HERE@gmail.com

# ──────────────────────────────────────────────────────────────
# CV storage (Vercel Blob) — https://vercel.com/docs/storage/vercel-blob
# ──────────────────────────────────────────────────────────────
# Create a Blob store in the Vercel dashboard, then copy the token.
# If omitted in local dev, the CV is saved to /tmp and the path is logged.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────
# Site
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://mafbootcamp.com
